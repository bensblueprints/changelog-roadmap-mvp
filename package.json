{
  "name": "shipnotes",
  "version": "1.0.0",
  "description": "Self-hosted changelog + roadmap + feature requests. Pay once, own it forever — no Canny subscription.",
  "author": "Ben (bensblueprints)",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "postinstall": "node scripts/setup-native.js",
    "desktop": "electron .",
    "test": "node test/smoke.js",
    "dist": "electron-builder --win nsis"
  },
  "dependencies": {
    "better-sqlite3": "^12.2.0",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "marked": "^15.0.6",
    "nodemailer": "^6.10.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "electron": "^33.4.0",
    "electron-builder": "^25.1.8",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.474.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.1.0",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.bensblueprints.shipnotes",
    "productName": "Shipnotes",
    "files": [
      "electron/**",
      "server/**",
      "dist/**",
      "vendor/**",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    },
    "asarUnpack": [
      "vendor/**"
    ]
  }
}
